{
  "name": "gastos-frontend",
  "version": "1.3.1",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "ng": "ng",
    "prebuild": "node scripts/write-firebase-api-key.mjs && node scripts/write-api-key.mjs",
    "prestart": "node scripts/write-firebase-api-key.mjs && node scripts/write-api-key.mjs",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "mobile:sync": "cap sync android",
    "mobile:open": "cap open android",
    "mobile:build": "npm run build && npm run mobile:sync && npm run mobile:open",
    "mobile:live": "ng serve --host 0.0.0.0",
    "mobile:publish-apk": "node scripts/publish-mobile-apk.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "chart.js": "^4.4.7",
    "firebase": "^12.14.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.26",
    "@angular/cli": "^20.3.26",
    "@angular/compiler-cli": "^20.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jasmine": "~6.0.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.3"
  }
}
